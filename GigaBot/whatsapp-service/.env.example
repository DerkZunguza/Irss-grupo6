# Número de sessões Baileys a manter em paralelo (mínimo recomendado: 2)
POOL_SIZE=2

# Porta da API REST
PORT=3001

# Redis (fila de mensagens)
REDIS_HOST=redis-wa
REDIS_PORT=6379

# Webhook — URL que recebe as mensagens recebidas (ex.: hardware-api)
WEBHOOK_URL=http://hardware-api:5000/api/whatsapp/incoming

# Token para autenticar chamadas à API deste serviço
API_TOKEN=mude_este_token_secreto

# Número do bot (opcional, para verificação)
BOT_NUMBER=258840000000
